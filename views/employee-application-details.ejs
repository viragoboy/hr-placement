<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>My Application</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="bg-body-tertiary">
  <main class="container py-4 py-md-5">
    <% if (bannerMessage) { %>
      <div class="alert alert-warning border" role="alert"><%= bannerMessage %></div>
    <% } %>

    <div class="card shadow-sm">
      <div class="card-body p-3 p-md-4 p-lg-5">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-4">
          <div>
            <h1 class="h3 mb-1">GCPS Placement Preference Form</h1>
            <p class="text-body-secondary mb-0">Review your submitted request and add additional preferred schools.</p>
          </div>
          <a class="btn btn-outline-secondary btn-sm" href="/my/applications">Back to my applications</a>
        </div>

        <% if (selectedLocationStatus) { %>
          <section class="mb-4">
            <h2 class="h5 border-bottom pb-2 mb-3">Selected Row</h2>
            <div class="alert alert-secondary mb-0">
              <strong><%= selectedLocationStatus.schoolName || selectedLocationStatus.schoolLoc %></strong>
              <span class="mx-2">•</span>
              <span>Status: <%= selectedLocationStatus.status || 'Submitted' %></span>
            </div>
          </section>
        <% } %>

        <% if (!user) { %>
          <div class="alert alert-danger" role="alert">User profile not found.</div>
        <% } %>

        <% if (errors.length) { %>
          <div class="alert alert-danger" role="alert">
            <p class="fw-semibold mb-2">Please fix the following:</p>
            <ul class="mb-0">
              <% errors.forEach(function(e){ %><li><%= e %></li><% }) %>
            </ul>
          </div>
        <% } %>

        <form method="post" action="/my/applications/<%= application.id %>/schools" class="needs-validation" novalidate>
          <input type="hidden" name="selectedSchoolLoc" value="<%= selectedLocationStatus?.schoolLoc || '' %>">

          <section class="mb-4">
            <h2 class="h5 border-bottom pb-2 mb-3">Employee Information</h2>
            <dl class="row row-cols-1 row-cols-md-2 g-3 mb-0">
              <div class="col"><dt class="small text-body-secondary mb-1">Name</dt><dd class="fw-semibold mb-0"><%= user?.displayName || '' %></dd></div>
              <div class="col"><dt class="small text-body-secondary mb-1">Employee ID</dt><dd class="fw-semibold mb-0"><%= user?.userId || '' %></dd></div>
              <div class="col"><dt class="small text-body-secondary mb-1">Current School</dt><dd class="fw-semibold mb-0"><%= user?.currentSchoolName || '' %></dd></div>
              <div class="col"><dt class="small text-body-secondary mb-1">Current Job Title</dt><dd class="fw-semibold mb-0"><%= user?.currentJobName || '' %></dd></div>
              <div class="col"><dt class="small text-body-secondary mb-1">Principal</dt><dd class="fw-semibold mb-0"><%= user?.principal || '' %></dd></div>
            </dl>
          </section>

          <section class="mb-4">
            <h2 class="h5 border-bottom pb-2 mb-3">Request Details</h2>
            <div class="row g-3">
              <div class="col-md-6">
                <label for="curPositionType" class="form-label">Current position type <span class="text-danger">*</span></label>
                <select id="curPositionType" class="form-select" name="curPositionType" disabled required>
                  <option value="">--Select--</option>
                  <option value="Teacher" <%= application?.curPositionType === 'Teacher' ? 'selected' : '' %>>Teacher</option>
                  <option value="Assistant Principal" <%= application?.curPositionType === 'Assistant Principal' ? 'selected' : '' %>>Assistant Principal</option>
                </select>
              </div>

              <div class="col-md-6">
                <label for="reasonForRequest" class="form-label">Reason for transfer <span class="text-danger">*</span></label>
                <select id="reasonForRequest" class="form-select" name="reasonForRequest" disabled required>
                  <option value="">--Select--</option>
                  <option value="Growth Opportunity" <%= application?.reasonForRequest === 'Growth Opportunity' ? 'selected' : '' %>>Growth Opportunity</option>
                  <option value="Commute" <%= application?.reasonForRequest === 'Commute' ? 'selected' : '' %>>Commute</option>
                  <option value="Other" <%= application?.reasonForRequest === 'Other' ? 'selected' : '' %>>Other</option>
                </select>
              </div>

              <% ['yearsOfTeaching', 'yearsOfAdmin', 'yearsOfCertificated', 'yearsTotalGCPS', 'yearsTotalExpNonGCPS'].forEach(function(field){ %>
                <div class="col-sm-6 col-lg-4">
                  <label class="form-label" for="<%= field %>"><%= field %> <span class="text-danger">*</span></label>
                  <input id="<%= field %>" class="form-control" type="number" min="0" name="<%= field %>" value="<%= application?.[field] ?? '' %>" readonly required />
                </div>
              <% }) %>
            </div>
          </section>

          <section class="mb-4">
            <h2 class="h5 border-bottom pb-2 mb-3">Verifications <span class="text-danger">*</span></h2>
            <div class="form-check mb-2">
              <input class="form-check-input" type="checkbox" id="verifyPDP" name="verifyPDP" <%= application?.verifyPDP ? 'checked' : '' %> disabled required>
              <label class="form-check-label" for="verifyPDP">I am not on PDP</label>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="verifyCertificate" name="verifyCertificate" <%= application?.verifyCertificate ? 'checked' : '' %> disabled required>
              <label class="form-check-label" for="verifyCertificate">I hold a renewable professional certificate</label>
            </div>
          </section>

          <section class="mb-4">
            <div class="d-flex justify-content-between align-items-center gap-2 border-bottom pb-2 mb-3">
              <h2 class="h5 mb-0">Preferred School Locations <span class="text-danger">*</span></h2>
              <span class="badge text-bg-info-subtle text-info-emphasis" id="selected-location-count">0 selected</span>
            </div>
            <% const categoryGroups = [
              { key: 'Elementary School', label: 'Elementary' },
              { key: 'Middle School', label: 'Middle' },
              { key: 'High School', label: 'High' },
              { key: 'Other', label: 'Other' }
            ]; %>
            <% const categoriesWithSchools = categoryGroups
              .map(group => ({
                ...group,
                cssClass: group.key.toLowerCase().replace(/[^a-z0-9]+/g, '-'),
                schools: schools.filter(s => s.category === group.key)
              }))
              .filter(group => group.schools.length); %>
            <% const maxRows = categoriesWithSchools.reduce((max, group) => Math.max(max, group.schools.length), 0); %>

            <% if (categoriesWithSchools.length) { %>
              <div class="table-responsive">
                <table class="table table-bordered align-middle mb-0">
                  <thead class="table-light">
                    <tr>
                      <% categoriesWithSchools.forEach(function(group){ %>
                        <th class="text-center fw-bold">
                          <div class="d-flex justify-content-between align-items-center gap-2">
                            <span><%= group.label %></span>
                            <button
                              class="btn btn-sm btn-outline-primary"
                              type="button"
                              data-category-toggle="<%= group.cssClass %>"
                              onclick="toggleCategorySelection('<%= group.cssClass %>')"
                            >
                              Select all
                            </button>
                          </div>
                        </th>
                      <% }) %>
                    </tr>
                  </thead>
                  <tbody>
                    <% for (let row = 0; row < maxRows; row++) { %>
                      <tr>
                        <% categoriesWithSchools.forEach(function(group){ const s = group.schools[row]; %>
                          <td>
                            <% if (s) { const inputId = `school-${group.cssClass}-${row}`; const isLocked = selectedLocations.includes(s.loc); %>
                              <div class="form-check">
                                <% if (isLocked) { %>
                                  <input type="hidden" name="preferredLocations" value="<%= s.loc %>" />
                                <% } %>
                                <input class="form-check-input school-group-<%= group.cssClass %>" type="checkbox" id="<%= inputId %>" name="preferredLocations" value="<%= s.loc %>" <%= isLocked ? 'checked disabled data-locked=true' : '' %> />
                                <label class="form-check-label" for="<%= inputId %>"><%= s.locname %> <%= isLocked ? '(already selected)' : '' %></label>
                              </div>
                            <% } %>
                          </td>
                        <% }) %>
                      </tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            <% } else { %>
              <p class="text-body-secondary mb-0">No school locations are currently available.</p>
            <% } %>
          </section>

          <section class="mb-4">
            <h2 class="h5 border-bottom pb-2 mb-3">Preferred Assignments (1-3) <span class="text-danger">*</span></h2>
            <% for (let i = 1; i <= 3; i++) { %>
              <div class="border rounded p-3 mb-3">
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label" for="prefTeachingAssignment<%= i %>">Assignment <%= i %></label>
                    <select id="prefTeachingAssignment<%= i %>" class="form-select" name="prefTeachingAssignment<%= i %>" disabled>
                      <option value="">--Select--</option>
                      <% jobs.forEach(function(job){ %>
                        <option value="<%= job.id %>" <%= String(application?.['prefTeachingAssignment'+i] || '') === String(job.id) ? 'selected' : '' %>><%= job.jobName %></option>
                      <% }) %>
                    </select>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label" for="additionalInfo<%= i %>">Additional info <%= i %></label>
                    <textarea id="additionalInfo<%= i %>" class="form-control" rows="2" name="additionalInfo<%= i %>" readonly><%= application?.['additionalInfo'+i] || '' %></textarea>
                  </div>
                </div>
              </div>
            <% } %>
          </section>

          <section class="mb-4">
            <h2 class="h5 border-bottom pb-2 mb-3">Certification</h2>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label" for="certificationID">Certification ID <span class="text-danger">*</span></label>
                <input id="certificationID" class="form-control" name="certificationID" value="<%= application?.certificationID || '' %>" required readonly />
              </div>
              <div class="col-md-6">
                <label class="form-label" for="certificateLevel">Certificate Level <span class="text-danger">*</span></label>
                <select id="certificateLevel" class="form-select" name="certificateLevel" required disabled>
                  <option value="">--Select--</option>
                  <% certificateLevels.forEach(function(lvl){ %>
                    <option value="<%= lvl %>" <%= application?.certificateLevel === lvl ? 'selected' : '' %>><%= lvl %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-12">
                <label class="form-label" for="fieldCertification">Field(s) of Certification <span class="text-danger">*</span></label>
                <textarea id="fieldCertification" class="form-control" rows="3" name="fieldCertification" required readonly><%= application?.fieldCertification || '' %></textarea>
              </div>
            </div>
          </section>

          <div class="d-flex justify-content-end border-top pt-3">
            <button type="submit" class="btn btn-primary px-4">Save additional schools</button>
          </div>
        </form>
      </div>
    </div>
  </main>

  <script>
    function setCategorySelection(category, checked) {
      document.querySelectorAll('.school-group-' + category).forEach(function(box){
        if (!box.dataset.locked) {
          box.checked = checked;
        }
      });
      refreshSelectedCount();
      refreshCategoryToggleButton(category);
    }

    function toggleCategorySelection(category) {
      const selectableBoxes = Array.from(document.querySelectorAll('.school-group-' + category))
        .filter(function(box) { return !box.dataset.locked; });
      const areAllChecked = selectableBoxes.length && selectableBoxes.every(function(box) { return box.checked; });
      setCategorySelection(category, !areAllChecked);
    }

    function refreshCategoryToggleButton(category) {
      const button = document.querySelector('[data-category-toggle="' + category + '"]');
      if (!button) return;

      const selectableBoxes = Array.from(document.querySelectorAll('.school-group-' + category))
        .filter(function(box) { return !box.dataset.locked; });
      const areAllChecked = selectableBoxes.length && selectableBoxes.every(function(box) { return box.checked; });
      button.textContent = areAllChecked ? 'Unselect all' : 'Select all';
    }

    function refreshAllCategoryToggleButtons() {
      document.querySelectorAll('[data-category-toggle]').forEach(function(button) {
        refreshCategoryToggleButton(button.dataset.categoryToggle);
      });
    }

    function refreshSelectedCount() {
      const checkedCount = document.querySelectorAll('input[name="preferredLocations"]:checked').length;
      const badge = document.getElementById('selected-location-count');
      if (badge) {
        badge.textContent = checkedCount + ' selected';
      }
    }

    document.querySelectorAll('input[name="preferredLocations"]').forEach(function(box) {
      box.addEventListener('change', function() {
        refreshSelectedCount();
        const categoryClass = Array.from(box.classList).find(function(className) { return className.startsWith('school-group-'); });
        if (categoryClass) {
          refreshCategoryToggleButton(categoryClass.replace('school-group-', ''));
        }
      });
    });

    refreshSelectedCount();
    refreshAllCategoryToggleButtons();
  </script>
</body>
</html>

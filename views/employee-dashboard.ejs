<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>My Applications</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="bg-body-tertiary">
  <% if (bannerMessage) { %><div class="banner"><%= bannerMessage %></div><% } %>
  <div class="container py-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <div class="d-flex flex-column flex-md-row justify-content-md-between align-items-md-center gap-2 mb-3">
          <div>
            <h1 class="h3 mb-1">My Placement Applications</h1>
            <p class="text-secondary mb-0">Review your submitted schools and open a row to add more schools.</p>
          </div>
        </div>

        <% if (selectedSchool || selectedStatus) { %>
          <div class="alert alert-secondary d-flex flex-column flex-md-row justify-content-md-between align-items-md-center gap-2 py-2">
            <div class="small">
              Showing selection:
              <span class="fw-semibold"><%= selectedSchool || 'All schools' %></span> /
              <span class="fw-semibold"><%= selectedStatus || 'All statuses' %></span>
            </div>
            <a href="/my/applications" class="btn btn-outline-secondary btn-sm">Clear selection</a>
          </div>
        <% } %>

        <% if (!Object.keys(grouped).length) { %>
          <div class="alert alert-info mb-0">You have not submitted any applications yet. <a href="/request">Start your application</a>.</div>
        <% } %>

        <div class="accordion mb-3" id="preferred-location-groups">
          <% Object.entries(grouped).forEach(([preferredLocation, statuses], index) => { %>
            <% const requestCount = Object.values(statuses).reduce((statusTotal, statusRows) => statusTotal + statusRows.length, 0); %>
            <div class="accordion-item">
              <h2 class="accordion-header" id="heading-<%= index %>">
                <button class="accordion-button <%= index > 0 ? 'collapsed' : '' %>" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-<%= index %>" aria-expanded="<%= index === 0 ? 'true' : 'false' %>" aria-controls="collapse-<%= index %>">
                  <strong><%= preferredLocation %></strong>&nbsp;<span class="badge bg-primary-subtle text-primary-emphasis rounded-pill"><%= requestCount %></span>
                </button>
              </h2>
              <div id="collapse-<%= index %>" class="accordion-collapse collapse <%= index === 0 ? 'show' : '' %>" aria-labelledby="heading-<%= index %>" data-bs-parent="#preferred-location-groups">
                <div class="accordion-body">
                  <% Object.entries(statuses).forEach(([status, statusRows]) => { %>
                    <div class="border rounded p-3 mb-3 bg-light-subtle">
                      <h4 class="h6 mb-3">Status: <span class="badge text-bg-secondary"><%= status %></span></h4>
                      <% statusRows.forEach((row) => { %>
                        <div class="card mb-2">
                          <div class="card-body d-flex flex-column flex-lg-row justify-content-between gap-3">
                            <div>
                              <div class="fw-semibold">
                                <a href="/my/applications/<%= row.id %>?schoolLoc=<%= encodeURIComponent(row.schoolLoc) %>" class="link-primary text-decoration-none"><%= preferredLocation %></a>
                              </div>
                              <div class="small text-secondary">
                                Submitted: <%= row.dateSubmitted ? new Date(row.dateSubmitted).toLocaleDateString() : '—' %> ·
                                Certification: <%= row.certificationID || '—' %> ·
                                Status: <%= status %>
                              </div>
                            </div>
                            <a class="btn btn-outline-primary btn-sm align-self-start" href="/my/applications/<%= row.id %>?schoolLoc=<%= encodeURIComponent(row.schoolLoc) %>">View application</a>
                          </div>
                        </div>
                      <% }) %>
                    </div>
                  <% }) %>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>

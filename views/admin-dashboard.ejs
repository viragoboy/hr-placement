<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Admin Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="bg-body-tertiary">
  <% if (bannerMessage) { %><div class="banner"><%= bannerMessage %></div><% } %>
  <div class="container py-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <div class="d-flex flex-column flex-md-row justify-content-md-between align-items-md-center gap-2 mb-3">
          <div>
            <h1 class="h3 mb-1">Placement Requests Dashboard</h1>
            <p class="text-secondary mb-0">Review requests, sort entries, and update statuses.</p>
          </div>
          <div class="btn-group" role="group" aria-label="Sort options">
            <a class="btn btn-outline-primary btn-sm <%= sortBy === 'employee' ? 'active' : '' %>" href="?sortBy=employee">Employee</a>
            <a class="btn btn-outline-primary btn-sm <%= sortBy === 'submitted' ? 'active' : '' %>" href="?sortBy=submitted">Submitted</a>
            <a class="btn btn-outline-primary btn-sm <%= sortBy === 'cert' ? 'active' : '' %>" href="?sortBy=cert">Certification</a>
            <a class="btn btn-outline-primary btn-sm <%= sortBy === 'status' ? 'active' : '' %>" href="?sortBy=status">Status</a>
          </div>
        </div>

        <% if (!Object.keys(grouped).length) { %>
          <div class="alert alert-info mb-0">No applications have been submitted yet.</div>
        <% } %>

        <div class="accordion mb-3" id="school-groups">
          <% Object.entries(grouped).forEach(([school, items], index) => { %>
            <div class="accordion-item">
              <h2 class="accordion-header" id="heading-<%= index %>">
                <button class="accordion-button <%= index > 0 ? 'collapsed' : '' %>" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-<%= index %>" aria-expanded="<%= index === 0 ? 'true' : 'false' %>" aria-controls="collapse-<%= index %>">
                  <strong><%= school %></strong>&nbsp;<span class="badge bg-primary-subtle text-primary-emphasis rounded-pill"><%= items.length %></span>
                </button>
              </h2>
              <div id="collapse-<%= index %>" class="accordion-collapse collapse <%= index === 0 ? 'show' : '' %>" aria-labelledby="heading-<%= index %>" data-bs-parent="#school-groups">
                <div class="accordion-body p-0">
                  <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                      <thead class="table-light">
                        <tr>
                          <th>Employee</th>
                          <th>Submitted</th>
                          <th>Certification</th>
                          <th>Preferred Locations</th>
                          <th>Status</th>
                          <th>Current Position / Principal</th>
                          <th class="text-nowrap">Actions</th>
                        </tr>
                      </thead>
                      <tbody>
                      <% items.forEach((row) => { %>
                        <tr>
                          <td class="fw-semibold"><%= row.displayName || '—' %></td>
                          <td><%= row.dateSubmitted ? new Date(row.dateSubmitted).toLocaleDateString() : '—' %></td>
                          <td><%= row.certificationID || '—' %></td>
                          <td><%= row.preferredLocations || '—' %></td>
                          <td><span class="badge text-bg-secondary"><%= row.formStatus || '—' %></span></td>
                          <td><%= row.curPositionType || '—' %> / <%= row.principal || '—' %></td>
                          <td>
                            <form class="d-flex gap-2" method="post" action="/admin/applications/<%= row.id %>/status">
                              <select name="status" class="form-select form-select-sm">
                                <% ['Submitted', 'Interview Requested', 'Not Available', 'Closed'].forEach((status) => { %>
                                  <option value="<%= status %>" <%= row.formStatus === status ? 'selected' : '' %>><%= status %></option>
                                <% }) %>
                              </select>
                              <button class="btn btn-primary btn-sm">Update</button>
                            </form>
                          </td>
                        </tr>
                      <% }) %>
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>
